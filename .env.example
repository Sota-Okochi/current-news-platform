# Required: OpenAI API key
OPENAI_API_KEY=sk-...

# Required: Notion internal integration secret
NOTION_API_KEY=secret_...

# Required: Notion database ID
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI model. Use a model available in your OpenAI project.
OPENAI_MODEL=gpt-4.1-mini

# Optional: OpenAI web search settings
OPENAI_WEB_SEARCH_TOOL=web_search_preview
OPENAI_SEARCH_CONTEXT_SIZE=low
OPENAI_MAX_OUTPUT_TOKENS=3500

# Optional: execution settings
TIMEZONE=Asia/Tokyo
ARTICLES_PER_RUN=3
LOOKBACK_LIMIT=12
CANDIDATE_COUNT=9
LOG_LEVEL=INFO

# Optional: Notion API version
NOTION_VERSION=2022-06-28

# Optional: Notion property names. Change only if your database uses different names.
NOTION_PROP_CHECKPOINT=チェックポイント
NOTION_PROP_TITLE=タイトル
NOTION_PROP_DATE=日付
NOTION_PROP_IMPORTANT_POINTS=重要ポイント
NOTION_PROP_CATEGORY=カテゴリ
NOTION_PROP_URL=URL
NOTION_PROP_RELIABILITY=信頼度
